{
  "schema_version": 2,
  "name": "完整功能开发流程",
  "description": "需求分析、实现与验收的三阶段示例。",
  "stages": [
    {
      "stage": 1,
      "name": "需求澄清",
      "execution_mode": "serial",
      "tasks": [
        {
          "id": "feature-prd",
          "title": "澄清需求并生成 spec",
          "type": "orchestrate",
          "description": "围绕以下需求产出事实清单、结构化 spec 和 orchestration_plan：{{requirement}}",
          "phase": "research",
          "phase_assignments": {
            "research": "supervisor",
            "synthesize": "supervisor",
            "implement": "supervisor",
            "integrate": "integrator",
            "verify": "inspector"
          },
          "expected_outputs": [
            "事实清单",
            "结构化 spec + orchestration_plan",
            "实施方案",
            "验收结论"
          ],
          "acceptance_criteria": [
            "research 只能产出事实",
            "synthesize 必须转成 capability-based 结构化 spec + orchestration_plan",
            "implement 如承接 synthesize 计划，完成时必须回报 executed_plan_step_ids + published_tasks + dispatch_receipts",
            "整体完成后才允许向 human 汇报"
          ],
          "impact_scope": "read_only",
          "execution_mode": "parallel",
          "resource_keys": [],
          "handoff_format": "markdown"
        }
      ]
    },
    {
      "stage": 2,
      "name": "实现",
      "execution_mode": "parallel",
      "tasks": [
        {
          "id": "backend-dev",
          "title": "实现后端改动",
          "type": "develop",
          "description": "基于上一阶段 spec 完成后端实现：{{feature-prd}}",
          "phase": "implement",
          "phase_assignments": {
            "research": "backend",
            "synthesize": "backend",
            "implement": "backend",
            "integrate": "integrator",
            "verify": "reviewer"
          },
          "expected_outputs": [
            "代码变更",
            "关键实现说明",
            "最终验收结论"
          ],
          "acceptance_criteria": [
            "代码可运行",
            "verify 通过后才完成"
          ],
          "impact_scope": "write",
          "execution_mode": "exclusive",
          "resource_keys": [
            "repo:backend"
          ],
          "handoff_format": "markdown",
          "verify": {
            "test": "echo '替换为真实后端测试命令'"
          }
        },
        {
          "id": "frontend-dev",
          "title": "实现前端改动",
          "type": "develop",
          "description": "基于上一阶段 spec 完成前端实现：{{feature-prd}}",
          "phase": "implement",
          "phase_assignments": {
            "research": "frontend",
            "synthesize": "frontend",
            "implement": "frontend",
            "integrate": "integrator",
            "verify": "reviewer"
          },
          "expected_outputs": [
            "代码变更",
            "交互说明",
            "最终验收结论"
          ],
          "acceptance_criteria": [
            "页面可构建",
            "verify 通过后才完成"
          ],
          "impact_scope": "write",
          "execution_mode": "exclusive",
          "resource_keys": [
            "repo:frontend"
          ],
          "handoff_format": "markdown",
          "verify": {
            "build": "echo '替换为真实前端构建命令'"
          }
        }
      ]
    }
  ]
}
