{
  "schema_version": 2,
  "name": "产品特性交付",
  "description": "面向完整产品特性的 V2 工作流示例。",
  "stages": [
    {
      "stage": 1,
      "name": "产品澄清",
      "execution_mode": "serial",
      "tasks": [
        {
          "id": "prd-spec",
          "title": "梳理需求并形成 spec",
          "type": "orchestrate",
          "description": "围绕产品需求形成事实清单和可执行 spec：{{requirement}}",
          "phase": "research",
          "phase_assignments": {
            "research": "prd",
            "synthesize": "architect",
            "implement": "supervisor",
            "integrate": "integrator",
            "verify": "inspector"
          },
          "expected_outputs": [
            "事实清单",
            "可执行 spec",
            "实施方案",
            "最终验收结论"
          ],
          "acceptance_criteria": [
            "research 只能产出事实",
            "synthesize 必须转成可执行 spec",
            "整体完成后才向 human 汇报"
          ],
          "impact_scope": "read_only",
          "execution_mode": "parallel",
          "resource_keys": [],
          "handoff_format": "markdown"
        }
      ]
    },
    {
      "stage": 2,
      "name": "并行实现",
      "execution_mode": "parallel",
      "tasks": [
        {
          "id": "backend-feature",
          "title": "实现后端功能",
          "type": "develop",
          "description": "基于产品 spec 完成后端实现：{{prd-spec}}",
          "phase": "implement",
          "phase_assignments": {
            "research": "backend",
            "synthesize": "backend",
            "implement": "backend",
            "integrate": "integrator",
            "verify": "reviewer"
          },
          "expected_outputs": [
            "后端代码",
            "关键接口说明",
            "最终验收结论"
          ],
          "acceptance_criteria": [
            "后端改动通过 verify",
            "输出包含关键风险"
          ],
          "impact_scope": "write",
          "execution_mode": "exclusive",
          "resource_keys": [
            "repo:backend"
          ],
          "handoff_format": "markdown",
          "verify": {
            "test": "echo '替换为真实后端测试命令'"
          }
        },
        {
          "id": "frontend-feature",
          "title": "实现前端功能",
          "type": "develop",
          "description": "基于产品 spec 完成前端实现：{{prd-spec}}",
          "phase": "implement",
          "phase_assignments": {
            "research": "frontend",
            "synthesize": "frontend",
            "implement": "frontend",
            "integrate": "integrator",
            "verify": "reviewer"
          },
          "expected_outputs": [
            "前端代码",
            "交互说明",
            "最终验收结论"
          ],
          "acceptance_criteria": [
            "前端改动通过 verify",
            "输出包含关键风险"
          ],
          "impact_scope": "write",
          "execution_mode": "exclusive",
          "resource_keys": [
            "repo:frontend"
          ],
          "handoff_format": "markdown",
          "verify": {
            "build": "echo '替换为真实前端构建命令'"
          }
        }
      ]
    },
    {
      "stage": 3,
      "name": "交付验收",
      "execution_mode": "serial",
      "tasks": [
        {
          "id": "release-check",
          "title": "汇总结果并完成验收",
          "type": "review",
          "description": "汇总前后端结果并形成最终验收：{{backend-feature}}\n\n{{frontend-feature}}",
          "phase": "verify",
          "phase_assignments": {
            "research": "inspector",
            "synthesize": "inspector",
            "implement": "inspector",
            "integrate": "integrator",
            "verify": "inspector"
          },
          "expected_outputs": [
            "最终验收结论",
            "上线风险清单"
          ],
          "acceptance_criteria": [
            "只在 verify 通过后完成",
            "结论可直接对 human 汇报"
          ],
          "impact_scope": "read_only",
          "execution_mode": "parallel",
          "resource_keys": [],
          "handoff_format": "markdown",
          "depends_on": [
            "backend-feature",
            "frontend-feature"
          ]
        }
      ]
    }
  ]
}
