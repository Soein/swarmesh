{
  "_comment": "swarmesh 角色权限默认模板（CLI 无关的语义层）。对应 Claude Code 官方 coordinatorMode.ts 的 Coordinator / InProcessTeammate / AsyncAgent 三层模型。由 scripts/lib/cli-permissions.sh 翻译为各家 CLI 的原生 flag。",
  "_merge_semantics": "数组字段 (allow_tools/deny_tools/allow_bash/deny_bash) 在 profile 覆盖时做 unique 追加合并，不是替换。详见 cli-launcher.sh::resolve_role_permissions。这意味着 role.permissions 里的额外 deny 规则会与默认规则共存，而不会丢失默认护栏（如 swarm-join.sh:* 防递归派发）。",
  "_deny_priority_note": "core 类型的 allow_bash 是通配 ['*']，依赖 Claude Code 官方语义: deny 规则优先级高于 allow。已通过反编译源码 bashPermissions.ts:1312 的 'Deny takes priority — return immediately' 确认。Gemini 通过 settings.json tools.exclude 实现同样语义。Codex 仅有粗粒度 sandbox，无细粒度白名单。",
  "_version": "1",

  "management": {
    "tier": "coordinator",
    "fs": "read-only",
    "exec": "ask",
    "allow_tools": ["read", "search", "list", "messaging"],
    "deny_tools": ["edit", "write", "delete"],
    "allow_bash": [
      "swarm-msg.sh:*",
      "swarm-status.sh:*",
      "swarm-join.sh:*",
      "swarm-leave.sh:*",
      "git status",
      "git log:*",
      "git diff:*",
      "git branch:*",
      "ls:*",
      "cat:*",
      "grep:*",
      "find:*",
      "jq:*",
      "echo:*",
      "wc:*"
    ],
    "deny_bash": [
      "rm:*",
      "sudo:*",
      "curl:*",
      "wget:*",
      "git push:*",
      "git commit:*",
      "git reset:*",
      "git rebase:*"
    ]
  },

  "quality": {
    "tier": "in_process_teammate",
    "fs": "read-only",
    "exec": "on-request",
    "allow_tools": ["read", "search", "list", "messaging", "test_runner"],
    "deny_tools": ["edit", "write", "delete"],
    "allow_bash": [
      "swarm-msg.sh:*",
      "git status",
      "git log:*",
      "git diff:*",
      "git branch:*",
      "npm test:*",
      "npm run test:*",
      "npm run lint:*",
      "pytest:*",
      "go test:*",
      "cargo test:*",
      "cargo check:*",
      "eslint:*",
      "ruff:*",
      "mypy:*",
      "ls:*",
      "cat:*",
      "grep:*",
      "find:*",
      "jq:*"
    ],
    "deny_bash": [
      "rm -rf:*",
      "sudo:*",
      "curl:*",
      "wget:*",
      "git push:*",
      "git commit:*",
      "git reset:*"
    ]
  },

  "core": {
    "tier": "async_agent",
    "fs": "workspace-write",
    "exec": "never-ask",
    "allow_tools": ["read", "write", "edit", "search", "list", "messaging", "bash"],
    "deny_tools": [],
    "allow_bash": ["*"],
    "deny_bash": [
      "sudo:*",
      "rm -rf /:*",
      "rm -rf ~:*",
      "rm -rf .git:*",
      "git push --force:*",
      "git push -f:*",
      "swarm-join.sh:*",
      "swarm-leave.sh:*",
      "swarm-msg.sh request-supervisor:*",
      "swarm-stop.sh:*",
      "tmux kill-session:*"
    ]
  }
}
